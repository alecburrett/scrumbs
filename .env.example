# Database (Railway provides DATABASE_URL automatically)
DATABASE_URL=postgresql://user:password@host:5432/scrumbs

# Auth.js v5
AUTH_SECRET=                    # openssl rand -hex 32
AUTH_URL=                       # https://{web-service}.up.railway.app
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Service communication
AGENT_SERVICE_URL=              # https://{agent-service}.up.railway.app
AGENT_SERVICE_SECRET=           # openssl rand -hex 32

# AI (agent service only)
ANTHROPIC_API_KEY=
