{
  "name": "scrumbs",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "dev": "npm run dev --workspace=apps/web",
    "db:migrate": "npm run migrate --workspace=packages/db",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:build-smoke": "vitest run apps/web/__tests__/build-smoke",
    "test:deploy-smoke": "vitest run apps/web/__tests__/deploy-smoke"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.0",
    "vitest": "^4.1.0"
  }
}
